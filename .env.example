# =====================================================
# migrate — credentials & runtime config
# =====================================================
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real credentials.

# ---- GCP / BigQuery -----------------------------------
# Option A (recommended for individual devs): use Application Default Credentials.
#   Run once on your machine: gcloud auth application-default login
#   Leave GCP_SERVICE_ACCOUNT_JSON empty.
#
# Option B (shared/CI): point to a Service Account JSON key file.
GCP_SERVICE_ACCOUNT_JSON=

# Comma-separated list of GCP project IDs you want to scan.
GCP_PROJECT_IDS=prj-finance-prod,prj-marketing-prod,prj-data-prod

# Optional — force a specific BQ region for the JOBS_BY_PROJECT (heatmap) query.
# If unset, the scanner detects each dataset's location automatically.
# Examples: us, eu, southamerica-east1, europe-west2
GCP_REGION=

# Optional — Composer DAGs bucket (for scanning the orchestration chain).
# Format: gs://<composer-env>-bucket  or gs://<bucket>/<prefix-to-dags>
GCP_COMPOSER_DAG_BUCKET=

# Optional — Vertex Workbench / GCS notebooks bucket.
GCP_NOTEBOOKS_BUCKET=

# ---- Databricks ---------------------------------------
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_DEFAULT_CATALOG=migrated_from_gcp
DATABRICKS_SQL_WAREHOUSE_ID=

# ---- LLM provider --------------------------------------
# Which provider is used by ALL LLM calls (DAG/notebook conversion + SQL fallback).
# One of: anthropic | openai | gemini | bedrock
LLM_PROVIDER=anthropic

# Anthropic (claude-*)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (gpt-*)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# AWS Bedrock (Claude models accessed via Bedrock)
# Auth comes from the standard boto3 chain: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# AWS_SESSION_TOKEN (if SSO), or ~/.aws/credentials.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# ---- Target platform -----------------------------------
# Where the framework should generate code for: 'databricks' or 'aws'.
# Drives LLM system prompts and artifact format (Databricks notebook + Workflow,
# vs MWAA-compatible Airflow DAG + S3-resident notebooks).
TARGET_PLATFORM=databricks

# ---- Target paths (where converted artifacts go on the new platform) ----
# Databricks: prefix in Workspace, e.g. /Workspace/migration
TARGET_DATABRICKS_WORKSPACE_PREFIX=/Workspace/migration

# AWS: S3 prefix for notebooks, MWAA bucket prefix for DAGs
TARGET_S3_NOTEBOOKS_PREFIX=s3://acme-data-notebooks/migration
TARGET_MWAA_DAGS_PREFIX=s3://acme-mwaa-bucket/dags

# ---- Web server ---------------------------------------
MIGRATE_WEB_HOST=127.0.0.1
MIGRATE_WEB_PORT=8000
