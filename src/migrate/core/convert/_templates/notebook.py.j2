{%- endif %}

# COMMAND ----------

dbutils.widgets.text("env", "dev", "Environment")
dbutils.widgets.text("run_id", "", "Run ID (optional)")

import logging
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
log = logging.getLogger("{{ table.name }}")

env = dbutils.widgets.get("env")
run_id = dbutils.widgets.get("run_id") or "manual"
target = "{{ target_fqn }}"

# COMMAND ----------

# MAGIC %md ## 1. Run converted SQL → temp view

# COMMAND ----------

CONVERTED_SQL = """
{{ converted_sql }}
"""

src_df = spark.sql(CONVERTED_SQL)
src_df.createOrReplaceTempView("_migrate_src")
log.info(f"source view materialized: {src_df.count():,} rows")

# COMMAND ----------

# MAGIC %md ## 2. Write to Delta target
{%- if merge_keys %}
# MAGIC
# MAGIC Strategy: **MERGE** on {% for k in merge_keys %}`{{ k }}`{% if not loop.last %}, {% endif %}{% endfor %}
{%- else %}
# MAGIC
# MAGIC Strategy: **OVERWRITE** (no merge keys detected — review and adjust if needed)
{%- endif %}

# COMMAND ----------

{% if merge_keys %}
merge_condition = " AND ".join([f"t.`{k}` = s.`{k}`" for k in {{ merge_keys|tojson }}])
spark.sql(f"""
MERGE INTO {target} t
USING _migrate_src s
ON {merge_condition}
WHEN MATCHED THEN UPDATE SET *
WHEN NOT MATCHED THEN INSERT *
""")
{% else %}
src_df.write.mode("overwrite").saveAsTable(target)
{% endif %}

# COMMAND ----------

# MAGIC %md ## 3. Assert row count and log

# COMMAND ----------

target_count = spark.sql(f"SELECT COUNT(*) AS c FROM {target}").collect()[0].c
log.info(f"target row count: {target_count:,}")

if target_count == 0:
    raise AssertionError(f"{target} is empty after migration")

# Optional: schema match check
expected_cols = {{ table.columns | map(attribute='name') | list | tojson }}
expected = {c.lower() for c in expected_cols}
actual = {col.lower() for col in spark.table(target).columns}
missing = expected - actual
if missing:
    raise AssertionError(f"Missing columns in target: {missing}")

# COMMAND ----------

import json
dbutils.notebook.exit(json.dumps({"target": target, "row_count": target_count, "run_id": run_id}))
